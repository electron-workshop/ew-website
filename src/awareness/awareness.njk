---
pagination:
  data: awarenessdays
  size: 1
  alias: day
permalink: "/awareness/{{ day.slug }}/"
layout: base.njk
eleventyComputed:
  title: "{{ day.title }} — Electron Workshop"
  description: "{{ day.description }}"
---

{# ── BANNER ───────────────────────────────────────────────────────────────── #}
{% if day.banner %}
  <div class="mb-4 rounded overflow-hidden shadow" style="max-height: 300px;">
    <img src="{{ day.banner }}" alt="{{ day.title }}" class="w-100 object-fit-cover" style="max-height: 300px;">
  </div>
{% else %}
  <div class="mb-4 rounded d-flex align-items-center justify-content-center bg-primary bg-opacity-10 border border-primary border-opacity-25" style="height: 180px;">
    <i class="bi {{ day.icon }} text-primary" style="font-size: 5rem; opacity: 0.25;"></i>
  </div>
{% endif %}

{# ── HEADER ───────────────────────────────────────────────────────────────── #}
<div class="row align-items-start g-4 mb-4">
  <div class="col-12 col-md-8">
    <p class="text-primary fw-bold text-uppercase mb-1" style="letter-spacing:.08em; font-size:.8rem;">
      <i class="bi bi-globe me-1"></i>Global Awareness Festival
    </p>
    <h1 class="display-6 fw-bold mb-3">{{ day.title }}</h1>
    <p class="lead text-secondary">{{ day.description }}</p>
    {% if day.externalHref %}
      <a href="{{ day.externalHref }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-box-arrow-up-right me-1"></i>Official {{ day.title }} website
      </a>
    {% endif %}
  </div>
  <div class="col-12 col-md-4">
    <div class="card border-primary border-opacity-50 shadow-sm text-center">
      <div class="card-body py-4">
        <p class="text-primary fw-bold text-uppercase mb-2 small" style="letter-spacing:.06em;">Next Occurrence</p>
        {% if day.dateRule %}
          <p class="h5 fw-bold mb-1">{{ day.dateRule | awarenessDate }}</p>
          <p class="text-secondary small mb-2">{{ day.dateRuleText }}</p>
          {% if day.dateRule | awarenessIsUpcoming(60) %}
            <span class="badge bg-primary">Coming soon</span>
          {% endif %}
        {% else %}
          <p class="h6 fw-semibold mb-1">{{ day.dateRuleText }}</p>
          <p class="text-secondary small mb-0">Check the official website for this year's date.</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<hr class="border-primary border-opacity-25 mb-5">

{# ── COMMUNITY EVENTS ─────────────────────────────────────────────────────── #}
<section class="mb-5">
  <h2 class="fs-4 fw-semibold mb-1">Community Events</h2>
  <p class="text-secondary mb-4">Events around the world celebrating {{ day.title }}, curated from community submissions.</p>

  {% set dayEvents = awarenessevents | filterByProp("daySlug", day.slug) %}

  {% if dayEvents.length %}
    <div class="row g-3 mb-4">
      {% for event in dayEvents %}
        <div class="col-12 col-md-6">
          <div class="card h-100 border-primary border-opacity-25 shadow-sm">
            <div class="card-body">
              <h3 class="h6 fw-semibold mb-2">
                {% if event.url %}
                  <a href="{{ event.url }}" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                    {{ event.name }} <i class="bi bi-box-arrow-up-right small"></i>
                  </a>
                {% else %}
                  {{ event.name }}
                {% endif %}
              </h3>
              <div class="d-flex flex-wrap gap-2 text-secondary small">
                {% if event.date %}
                  <span><i class="bi bi-calendar3 me-1"></i>{{ event.date }}{% if event.time %} · {{ event.time }}{% endif %}</span>
                {% endif %}
                {% if event.location %}
                  <span><i class="bi bi-geo-alt me-1"></i>{{ event.location.city }}, {{ event.location.country }}</span>
                {% endif %}
                {% if event.timezone %}
                  <span><i class="bi bi-clock me-1"></i>{{ event.timezone }}</span>
                {% endif %}
                {% if event.language %}
                  <span><i class="bi bi-translate me-1"></i>{{ event.language }}</span>
                {% endif %}
              </div>
              {% if event.description %}
                <p class="text-secondary small mt-2 mb-0">{{ event.description }}</p>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="border border-primary border-opacity-25 rounded p-5 text-center text-secondary mb-4">
      <i class="bi bi-calendar-plus fs-1 mb-3 d-block opacity-25"></i>
      <p class="mb-0">No events listed yet — be the first to add one below.</p>
    </div>
  {% endif %}
</section>

{# ── SUBMIT AN EVENT ──────────────────────────────────────────────────────── #}
<section class="bg-body-tertiary border border-primary border-opacity-25 rounded p-4 mb-5">
  <h2 class="fs-5 fw-semibold mb-1">Add an Event</h2>
  <p class="text-secondary small mb-4">
    Know of an event celebrating {{ day.title }}? Submit it here — after a quick review it'll appear on this page.
    Include location and timezone so we can map events globally.
  </p>

  <form name="awareness-event-submission" method="POST" netlify novalidate class="needs-validation">
    <input type="hidden" name="daySlug" value="{{ day.slug }}">
    <input type="hidden" name="dayTitle" value="{{ day.title }}">
    <div class="visually-hidden" aria-hidden="true">
      <input type="text" name="company" tabindex="-1" autocomplete="off">
    </div>

    <div class="row g-3">
      <div class="col-12 col-md-6">
        <label class="form-label" for="event-name">Event name *</label>
        <input type="text" class="form-control" id="event-name" name="name" required>
        <div class="invalid-feedback">Please enter the event name.</div>
      </div>
      <div class="col-12 col-md-6">
        <label class="form-label" for="event-url">Event URL</label>
        <input type="url" class="form-control" id="event-url" name="url" placeholder="https://...">
      </div>
      <div class="col-6 col-md-3">
        <label class="form-label" for="event-date">Date *</label>
        <input type="date" class="form-control" id="event-date" name="date" required>
        <div class="invalid-feedback">Please enter the date.</div>
      </div>
      <div class="col-6 col-md-3">
        <label class="form-label" for="event-time">Start time</label>
        <input type="time" class="form-control" id="event-time" name="time">
      </div>
      <div class="col-12 col-md-6">
        <label class="form-label" for="event-timezone">Timezone *</label>
        <input type="text" class="form-control" id="event-timezone" name="timezone"
               placeholder="e.g. Australia/Melbourne, UTC+10, EST" required>
        <div class="invalid-feedback">Please enter the timezone.</div>
      </div>
      <div class="col-12 col-md-4">
        <label class="form-label" for="event-city">City *</label>
        <input type="text" class="form-control" id="event-city" name="city" required>
        <div class="invalid-feedback">Please enter the city.</div>
      </div>
      <div class="col-12 col-md-4">
        <label class="form-label" for="event-country">Country *</label>
        <input type="text" class="form-control" id="event-country" name="country" required>
        <div class="invalid-feedback">Please enter the country.</div>
      </div>
      <div class="col-12 col-md-4">
        <label class="form-label" for="event-language">Language(s) *</label>
        <input type="text" class="form-control" id="event-language" name="language"
               placeholder="e.g. English, Spanish" required>
        <div class="invalid-feedback">Please enter the language(s).</div>
      </div>
      <div class="col-12">
        <label class="form-label" for="event-description">Brief description</label>
        <textarea class="form-control" id="event-description" name="description" rows="2"
                  placeholder="What's happening at the event?"></textarea>
      </div>
      <div class="col-12">
        <button type="submit" class="btn btn-primary">Submit Event</button>
        <p class="text-secondary small mt-2 mb-0">
          <i class="bi bi-info-circle me-1"></i>Submitted events are reviewed before appearing on this page.
        </p>
      </div>
    </div>
  </form>
</section>

<script>
(() => {
  'use strict';
  const forms = document.querySelectorAll('.needs-validation');
  Array.from(forms).forEach(form => {
    form.addEventListener('submit', event => {
      const hp = form.querySelector('[name="company"]');
      if (hp && hp.value.trim()) { event.preventDefault(); event.stopPropagation(); return; }
      if (!form.checkValidity()) { event.preventDefault(); event.stopPropagation(); }
      form.classList.add('was-validated');
    }, false);
  });
})();
</script>
