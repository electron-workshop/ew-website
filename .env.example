# ─────────────────────────────────────────────────────────────────────────────
# Electron Workshop – environment variables reference
#
# Copy this file to .env for local dev (never commit .env).
# In production, set these in the Netlify dashboard:
#   Site configuration → Environment variables
#
# GitHub Actions secrets are set separately in:
#   GitHub repo → Settings → Secrets and variables → Actions
# ─────────────────────────────────────────────────────────────────────────────


# ── Telegram bot (shared by both workflows) ───────────────────────────────────
# A single bot can post to multiple chats/topics.
# Create a bot via @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=


# ── GitHub event notifications (pr_notify.yml GitHub Action) ─────────────────
# The chat and topic (thread) that receives PR / issue / push events.
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=


# ── Netlify form submission notifications (netlify/functions/form-notify.js) ──
# All forms post to this single chat/topic.
TELEGRAM_FORMS_CHAT_ID=
TELEGRAM_FORMS_THREAD_ID=          # optional – omit if the group has no topics


# ── BigBlueButton status function (netlify/functions/bbb-status.js) ───────────
BBB_URL=
BBB_SECRET=
